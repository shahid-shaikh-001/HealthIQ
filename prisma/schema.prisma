generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"

  // The `url` property was removed from schema files in Prisma v7.
  // Move connection URLs for Migrate to prisma.config.ts and
  // pass `adapter` or `accelerateUrl` to the PrismaClient constructor.
  // See: https://pris.ly/d/config-datasource
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  documents     MedicalDocument[]
  healthMetrics HealthMetric[]
  healthScores  HealthScore[]
}

model MedicalDocument {
  id               String            @id @default(cuid())
  userId           String

  title            String
  fileUrl          String
  fileType         String
  fileSize         Int?
  documentType     DocumentType      @default(OTHER)
  processingStatus ProcessingStatus  @default(PENDING)

  extractedText    String?
  aiSummary        String?

  uploadedAt       DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthMetrics    HealthMetric[]

  @@index([userId])
  @@index([processingStatus])
}

model HealthMetric {
  id          String        @id @default(cuid())
  userId      String
  documentId  String?

  name        String
  value       Float?
  unit        String?
  normalMin   Float?
  normalMax   Float?
  status      MetricStatus  @default(UNKNOWN)

  testedAt    DateTime?
  createdAt   DateTime      @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    MedicalDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([name])
  @@index([status])
}

model HealthScore {
  id            String      @id @default(cuid())
  userId        String

  score         Int
  riskLevel     RiskLevel   @default(LOW)
  summary       String?

  calculatedAt  DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([riskLevel])
}

enum DocumentType {
  BLOOD_REPORT
  PRESCRIPTION
  SCAN_REPORT
  CHECKUP_REPORT
  OTHER
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MetricStatus {
  LOW
  NORMAL
  HIGH
  CRITICAL
  UNKNOWN
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  CRITICAL
}